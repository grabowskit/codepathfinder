#==================================================#
#                  LibreChat Config                 #
#==================================================#

# Security Keys (generate your own!)
CREDS_KEY=your-32-char-credentials-key-here
CREDS_IV=your-16-char-iv-here
JWT_SECRET=your-jwt-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# MongoDB (LibreChat's database)
MONGO_URI=mongodb://mongodb:27017/librechat

# MeiliSearch (LibreChat's search)
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=masterkey

#==================================================#
#                   LLM API Keys                    #
#==================================================#
# These keys are read by LibreChat via environment variable references
# in the dynamic config from CodePathfinder.
#
# To add/manage LLM providers:
# 1. Configure providers in CodePathfinder admin (/admin/core/llmprovider/)
# 2. Set the corresponding API key here
# 3. Restart LibreChat: docker-compose restart librechat

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=

#==================================================#
#          CodePathfinder MCP Integration           #
#==================================================#

# Internal service secret - shared between CodePathfinder and LibreChat
# This is set automatically via docker-compose environment variables
# No manual API key creation required!
# CPF_INTERNAL_SERVICE_SECRET is passed from docker-compose.yml

#==================================================#
#               Optional Settings                   #
#==================================================#

# Debug mode
DEBUG_CONSOLE=false

# Allow registration
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# Email (optional)
# EMAIL_SERVICE=
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USERNAME=
# EMAIL_PASSWORD=
# EMAIL_FROM=
